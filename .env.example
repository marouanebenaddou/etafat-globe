# ─── ETAFAT Globe — environment template ─────────────────────────────────
# Copy this file to .env.local for development and override per environment.

# URL of the GNSS processing backend (FastAPI + RTKLIB).
# Locally:     http://localhost:8000   (run `cd backend && uvicorn app:app --port 8000`)
# Production:  https://gnss-api.etafat.example.com   (set in Vercel env vars)
NEXT_PUBLIC_GNSS_API_URL=http://localhost:8000
